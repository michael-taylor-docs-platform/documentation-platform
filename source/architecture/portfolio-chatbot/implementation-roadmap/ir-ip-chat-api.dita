<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE concept PUBLIC "-//OASIS//DTD DITA Concept//EN" "concept.dtd">
<concept id="concept_imx_2yv_m3c">
    <title>Phase 4 — Chat API</title>
    <conbody>
        <section id="section_jbn_gyv_m3c">
            <title>Goal</title>
            <p>Implement the chatbot API endpoint.</p>
        </section>
        <section id="section_kbn_gyv_m3c">
            <title>Component</title>
            <pre>api/chat</pre>
            <p>Endpoint:</p>
            <pre>POST /api/chat</pre>
        </section>
        <section id="section_lbn_gyv_m3c">
            <title>Tasks</title>
            <ul id="ul_fny_3yv_m3c">
                <li>
                    <p><b>Accept Chat Request</b></p>
                    <p>Input: user query</p>
                </li>
                <li>
                    <p><b>Execute Retrieval Pipeline</b></p>
                    <p>Includes:</p>
                    <ul id="ul_rwb_qnd_w3c">
                        <li>
                            <p>query expansion</p>
                        </li>
                        <li>
                            <p>intent classification</p>
                        </li>
                        <li>
                            <p>hybrid retrieval</p>
                        </li>
                        <li>
                            <p>reranking</p>
                        </li>
                        <li>
                            <p>graph expansion</p>
                        </li>
                    </ul>
                </li>
                <li>
                    <p><b>Construct Prompt</b></p>
                    <p>Combine:</p>
                    <ul id="ul_cfm_snd_w3c">
                        <li>
                            <p>user query</p>
                        </li>
                        <li>
                            <p>intent-aware instructions</p>
                        </li>
                        <li>
                            <p>retrieved context blocks</p>
                        </li>
                    </ul>
                </li>
                <li>
                    <p><b>Call LLM API</b></p>
                    <p>Generate streamed response</p>
                </li>
                <li>
                    <p><b>Return Response</b></p>
                    <p>Include:</p>
                    <ul id="ul_zfs_5nd_w3c">
                        <li>
                            <p>generated answer</p>
                        </li>
                        <li>
                            <p>source references</p>
                        </li>
                    </ul>
                </li>
            </ul>
        </section>
        <section id="section_mbn_gyv_m3c">
            <title>Deliverables</title>
            <ul id="ul_qbn_gyv_m3c">
                <li>
                    <p>chat API endpoint</p>
                </li>
                <li>
                    <p>LLM integration</p>
                </li>
                <li>
                    <p>response formatting</p>
                </li>
            </ul>
        </section>
    </conbody>
</concept>
